# LLM — set ONE provider key (all others can be left empty)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=sk-hXd6xMNhRdcqoYwRXpQGzqvIQekd0mLjsV5bHwjoTSSy__EzZj
OPENROUTER_API_KEY=sk-or-v1-352164cc8d3a306cff2681b12dbb8c406d5b1__88f5e58a871339443fac234a04a
GROQ_API_KEY=gsk_8yy21OLydPZQX32nOJxoWGdyb3FYwqcyjOdCnfEJW5DKK__VOTQ4ph

# Provider: groq (free) | openrouter (free) | moonshot | anthropic | openai
LLM_PROVIDER=groq

# Optional: override model
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free`

# Embedding model size: "small" or "large"
EMBEDDING_MODEL=small

# NER: set true for faster dev mode
USE_SPACY_FALLBACK=false

# Storage
DATABASE_URL=sqlite:///data/news_kg.db
CHROMA_PERSIST_DIR=data/chroma_db

# Optional: seed ontology file (leave empty to start from scratch)
SEED_ONTOLOGY_PATH=config/seed_ontology.yaml

# Enable dynamic discovery
ENABLE_TYPE_INDUCTION=true
ENABLE_RELATION_CLUSTERING=true

# Clustering
TEMPORAL_WINDOW_DAYS=7
MIN_CLUSTER_SIZE=3

# Deduplication
SIMILARITY_THRESHOLD=0.95

# Entity merging
ENTITY_MERGE_THRESHOLD=0.88

# Batch sizes
NER_BATCH_SIZE=32
EMBEDDING_BATCH_SIZE=64
